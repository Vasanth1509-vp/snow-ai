# Database Configuration
DATABASE_URL=postgresql://snowai:snowai123@localhost:5432/snowai

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AI Service API Keys (Optional - AI features will use fallback responses if not provided)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Security
SECRET_KEY=your-secret-key-here-please-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ServiceNow Community URLs
SERVICENOW_COMMUNITY_BASE_URL=https://community.servicenow.com

# Scraping Configuration
SCRAPING_DELAY=1
MAX_PAGES_TO_SCRAPE=100